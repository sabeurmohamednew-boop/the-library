generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Book {
  id               String   @id @default(cuid())
  slug             String   @unique
  title            String
  description      String
  author           String
  format           String
  category         String
  pageCount        Int
  publicationDate  DateTime
  uploadDate       DateTime @default(now())
  bookBlobUrl      String
  bookBlobPath     String
  coverBlobUrl     String
  coverBlobPath    String
  fileSize         Int
  fileContentType  String
  coverContentType String
  searchText       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([format])
  @@index([category])
  @@index([publicationDate])
  @@index([uploadDate])
  @@index([author])
  @@index([title])
}
