generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Book {
  id              String       @id @default(cuid())
  slug            String       @unique
  title           String
  description     String
  author          String
  format          String
  category        String
  pageCount       Int
  publicationDate DateTime
  uploadDate      DateTime     @default(now())
  coverImagePath  String
  filePath        String
  fileSize        Int
  searchText      String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([format])
  @@index([category])
  @@index([publicationDate])
  @@index([uploadDate])
  @@index([author])
  @@index([title])
}
